<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ESTILO BASE (el que faltaba) -->
    <style name="TextAppearance.FinSell" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ESTILOS DERIVADOS -->
    <style name="TextAppearance.FinSell.Title">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.FinSell.Body">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.FinSell.Secondary">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.FinSell.Total">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ESTILOS DE BOTONES -->
    <style name="Widget.FinSell.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">24dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.FinSell.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">24dp</item>
        <item name="android:textSize">14sp</item>
        <item name="strokeColor">@color/pos_gray_border</item>
    </style>
</resources>