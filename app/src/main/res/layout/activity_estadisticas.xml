<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
<TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📊 Estadísticas del día" android:textSize="24sp" android:textStyle="bold" />
<TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Ventas simples" android:textStyle="bold" />
<TextView android:id="@+id/txtTotalSimple" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="$0.00" />
<TextView android:id="@+id/txtCantidadSimple" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="0 ventas" />
<TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Cuentas cerradas" android:textStyle="bold" />
<TextView android:id="@+id/txtTotalCuentas" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="$0.00" />
<TextView android:id="@+id/txtCantidadCuentas" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="0 cuentas" />
<com.github.mikephil.charting.charts.BarChart android:id="@+id/chart" android:layout_width="match_parent" android:layout_height="260dp" />
<TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Top 5 productos" android:textStyle="bold" />
<TextView android:id="@+id/txtTopProductos" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sin ventas" />
<com.google.android.material.button.MaterialButton android:id="@+id/btnExportar" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Exportar ventas del día" />
<com.google.android.material.button.MaterialButton android:id="@+id/btnVolver" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Volver" />
</LinearLayout>
</ScrollView>
