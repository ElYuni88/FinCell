<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background">

    <!-- ============================================ -->
    <!-- CONTENIDO PRINCIPAL (todo lo que ya tenías) -->
    <!-- ============================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar (ya existe) -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/pos_green"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:title="CafePos"
            app:titleTextColor="@android:color/white">
        </com.google.android.material.appbar.MaterialToolbar>

        <!-- ScrollView con todo tu contenido existente -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:animateLayoutChanges="true"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- ChipGroup (Modo Simple / Cuenta) -->
                <com.google.android.material.chip.ChipGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSimple"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="MODO SIMPLE"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        app:chipBackgroundColor="@color/card_background"
                        app:chipStrokeColor="@color/pos_green"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCuenta"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="MODO CUENTA"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        app:chipBackgroundColor="@color/card_background"
                        app:chipStrokeColor="@color/pos_blue"
                        app:chipStrokeWidth="1dp" />
                </com.google.android.material.chip.ChipGroup>

                <!-- Panel Simple (Modo Simple) -->
                <LinearLayout
                    android:id="@+id/panelSimple"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:animateLayoutChanges="true"
                    android:background="@drawable/modo_simple_bg"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="● MODO VENTA DIRECTA"
                            android:textColor="@color/pos_green"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/imgCalendarioSimple"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="Seleccionar fecha"
                            android:padding="4dp"
                            android:src="@drawable/ic_calendar" />

                        <TextView
                            android:id="@+id/txtFechaSimple"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:padding="4dp"
                            android:text="Fecha: --/--/----"
                            android:textAppearance="@style/TextAppearance.FinSell.Secondary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEscanearSimple"
                        android:stateListAnimator="@animator/press_scale"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginTop="16dp"
                        android:elevation="8dp"
                        android:text="📷  ESCANEAR PRODUCTO"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/primary_container"
                        app:icon="@drawable/ic_barcode_scanner"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAgregarManualSimple"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="✏️ Agregar Producto Manual"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/primary"
                        app:icon="@drawable/ic_edit"
                        app:iconTint="@color/white"
                        app:strokeColor="@color/primary"
                        app:strokeWidth="1dp"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        app:cardBackgroundColor="@color/card_background"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Resumen del día"
                                android:textAppearance="@style/TextAppearance.FinSell.Title" />

                            <TextView
                                android:id="@+id/txtTotalDia"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="$0.00"
                                android:textAppearance="@style/TextAppearance.FinSell.Total" />

                            <TextView
                                android:id="@+id/txtCantidadDia"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0 productos"
                                android:textAppearance="@style/TextAppearance.FinSell.Secondary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/card_background"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Última venta"
                                android:textAppearance="@style/TextAppearance.FinSell.Title" />

                            <TextView
                                android:id="@+id/txtUltimaVenta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Sin ventas todavía"
                                android:textAppearance="@style/TextAppearance.FinSell.Body" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerVentas"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="10dp"
                        android:clipToPadding="false"
                        android:paddingBottom="8dp" />
                </LinearLayout>

                <!-- Panel Cuenta (Modo Cuenta) -->
                <LinearLayout
                    android:id="@+id/panelCuenta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:animateLayoutChanges="true"
                    android:background="@drawable/modo_cuenta_bg"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="● MODO CUENTAS POR CLIENTE"
                            android:textColor="@color/pos_blue"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/imgCalendarioCuenta"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="Seleccionar fecha"
                            android:padding="4dp"
                            android:src="@drawable/ic_calendar" />

                        <TextView
                            android:id="@+id/txtFechaCuenta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?attr/selectableItemBackground"
                            android:padding="4dp"
                            android:text="Fecha: --/--/----"
                            android:textAppearance="@style/TextAppearance.FinSell.Secondary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtCuentasAbiertasInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Cuentas abiertas: 0"
                        android:textAppearance="@style/TextAppearance.FinSell.Secondary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNuevaCuenta"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="16dp"
                        android:text="➕ CREAR NUEVA CUENTA"
                        android:textColor="@color/pos_blue_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/create_account_background"
                        app:cornerRadius="24dp" />

                    <TextView
                        android:id="@+id/txtCuentaSeleccionada"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Ninguna cuenta seleccionada"
                        android:textAppearance="@style/TextAppearance.FinSell.Secondary"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEscanearCuenta"
                        android:visibility="gone"
                        android:stateListAnimator="@animator/press_scale"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="12dp"
                        android:text="📷  ESCANEAR (agregar a cuenta)"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@color/pos_blue"
                        app:cornerRadius="24dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerCuentas"
                        android:layout_width="match_parent"
                        android:layout_height="360dp"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:paddingBottom="8dp"
                        tools:listitem="@layout/item_cuenta" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerCuenta"
                        android:visibility="gone"
                        style="@style/Widget.FinSell.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:text="VER CUENTA SELECCIONADA"
                        android:textColor="@color/pos_blue" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAltaProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:contentDescription="Dar alta a producto escaneado"
            app:backgroundTint="@color/pos_green"
            app:srcCompat="@drawable/ic_box_add"
            app:tint="@android:color/white" />

        <!-- BottomNavigationView (barra inferior) -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            style="@style/Widget.FinSell.BottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@color/surface"
            app:menu="@menu/menu_bottom"
            app:itemIconTint="@color/bottom_nav_tint"
            app:itemTextColor="@color/bottom_nav_tint" />

    </LinearLayout>

    <!-- ============================================ -->
    <!-- NAVIGATION DRAWER (menú lateral)             -->
    <!-- ============================================ -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/menu_navigation"
        app:itemIconTint="@color/on_surface_variant"
        app:itemTextColor="@color/on_surface"
        app:itemBackground="@color/transparent" />

</androidx.drawerlayout.widget.DrawerLayout>